# GitHub Personal Access Token (classic)
# Required scopes: repo, read:user
# Generate: https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional — Google Gemini API for AI README summaries (free tier).
# Get a key: https://aistudio.google.com/apikey
# Leave empty to disable AI summaries (the rest of the app still works).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional — Basic auth gate. Required for production deployment.
# If unset, the dashboard is open (use only for local dev).
DASHBOARD_USER=
DASHBOARD_PASSWORD=
